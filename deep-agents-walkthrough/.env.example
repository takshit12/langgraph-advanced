# Copy this file to .env (in this same folder) and fill in your keys.
# competitive_analysis_agent/langgraph.json loads this file via "env": "../.env".

# --- Model gateway (required) ---
# Get a key at https://openrouter.ai/keys (needs a small credit balance).
OPENROUTER_API_KEY=
# Any model id OpenRouter serves, e.g. openai/gpt-4.1-mini, openai/gpt-5, anthropic/claude-sonnet-4-6
OPENROUTER_MODEL=openai/gpt-4.1-mini

# --- Web search (required) ---
# Free tier (1,000 credits) at https://app.tavily.com
TAVILY_API_KEY=

# --- LangSmith tracing (optional but recommended) ---
# Key from https://smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=deep_competitive_analysis
