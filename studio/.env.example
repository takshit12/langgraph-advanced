# Copy this file to .env and fill in your own values:  cp .env.example .env
#
# --- Langfuse Cloud (free tier) -------------------------------------------------
# Get a key pair at  cloud.langfuse.com  ->  Settings -> API Keys.
# IMPORTANT: LANGFUSE_HOST must match the REGION where you created your account.
# A US account talking to the EU host (or vice-versa) silently sends nothing.
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
LANGFUSE_HOST=https://cloud.langfuse.com         # EU  (default)
# LANGFUSE_HOST=https://us.cloud.langfuse.com    # US
# LANGFUSE_HOST=https://jp.cloud.langfuse.com    # Japan

# --- OpenRouter (OPTIONAL) ------------------------------------------------------
# Only the "question" branch uses this. Leave it blank and the agent returns a
# deterministic offline answer, so the deploy/observe/evaluate demos all still work.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
